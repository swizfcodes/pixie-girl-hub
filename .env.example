# ============================================================
# PIXIE GIRL HUB — BACKEND ENVIRONMENT VARIABLES
# Copy to .env and fill in real values. NEVER commit .env to git.
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=pixiegirl-hub-backend
APP_URL=http://localhost:3000
LOG_LEVEL=info

# ── PostgreSQL ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pixie_hub
DB_USER=pixie_app
DB_PASSWORD=__set_a_strong_password__
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=false
DB_STATEMENT_TIMEOUT_MS=30000

# ── Redis (cache, sessions, BullMQ queue) ───────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Authentication ──────────────────────────────────────────
JWT_SECRET=__generate_a_long_random_string__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d
SESSION_SECRET=__another_long_random_string__
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# ── Encryption (AES-256 for credentials at rest) ────────────
ENCRYPTION_KEY=__exactly_32_bytes_hex_encoded__

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
TRUSTED_PROXIES=loopback,linklocal,uniquelocal

# ── Storage (self-hosted media per V2.2 spec) ───────────────
STORAGE_KIND=local
STORAGE_LOCAL_ROOT=./media
CDN_BASE_URL=
MEDIA_MAX_FILE_SIZE_MB=200

# ── FFmpeg ──────────────────────────────────────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# ── Payment Gateways ────────────────────────────────────────
# Paystack (NGN)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Opay (NGN — primary/fallback pair with Paystack)
OPAY_PUBLIC_KEY=
OPAY_PRIVATE_KEY=
OPAY_MERCHANT_ID=
# Nomba (POS)
NOMBA_API_KEY=
NOMBA_ACCOUNT_ID=
# Stripe (international)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Logistics ───────────────────────────────────────────────
CHOWDECK_API_KEY=
GIGL_API_KEY=
DHL_API_KEY=

# ── Communication ───────────────────────────────────────────
# Meta WhatsApp Cloud API
META_WA_PHONE_ID=
META_WA_TOKEN=
META_WA_VERIFY_TOKEN=
# Instagram Graph API
META_IG_PAGE_ID=
META_IG_ACCESS_TOKEN=
META_GRAPH_VERIFY_TOKEN=
# SMTP (transactional email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# ── Social Media APIs ───────────────────────────────────────
META_GRAPH_APP_ID=
META_GRAPH_APP_SECRET=
TIKTOK_BUSINESS_API_KEY=
YOUTUBE_DATA_API_KEY=

# ── Marketing ───────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
META_MARKETING_API_KEY=

# ── E-Commerce (WooCommerce sync) ───────────────────────────
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# ── Geolocation ─────────────────────────────────────────────
MAXMIND_DB_PATH=./data/GeoLite2-Country.mmdb

# ── AI (per V2.2 §8.1) ──────────────────────────────────────
# DeepSeek (LLM)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Groq (Whisper transcription)
GROQ_API_KEY=
# OpenAI (embeddings only)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# AI budget enforcement
AI_MONTHLY_SOFT_CAP_NGN=75000
AI_MONTHLY_HARD_CAP_NGN=80000

# ── Observability ───────────────────────────────────────────
SENTRY_DSN=
ENABLE_REQUEST_LOGGING=true
ENABLE_AUDIT_LOG=true

# ── Feature flags ───────────────────────────────────────────
FEATURE_MANUAL_PAYMENTS_ENABLED=false
FEATURE_PRAXIS_VOICE_ENABLED=true
FEATURE_UGC_INGESTION_ENABLED=true

# ── Cron schedules (in your tz) ─────────────────────────────
TZ=Africa/Lagos
CRON_DAILY_AI_BRIEFING=0 7 * * *
CRON_WEEKLY_SALES_REPORT=0 20 * * 6
CRON_WEEKLY_CUSTOMER_REPORT=0 20 * * 6
CRON_LAYAWAY_ABANDONMENT_CHECK=0 2 * * *
CRON_FX_RATE_REFRESH=0 6 * * *
CRON_LOW_STOCK_ALERTS=0 8,14 * * *

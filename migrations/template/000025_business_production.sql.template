-- ── service_job_chemicals ────────────────────────────────
-- Per-job chemical consumption (for Colour Creation and any other
-- service that uses chemicals). Feeds monthly_chemical_reconciliations.
CREATE TABLE {{BUSINESS}}.service_job_chemicals (
  consumption_id        UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  job_id                UUID        NOT NULL REFERENCES {{BUSINESS}}.service_jobs (job_id) ON DELETE CASCADE,
  chemical_name         TEXT        NOT NULL,
  chemical_brand        TEXT,
  -- Variant linkage if the chemical is also a tracked product
  variant_id            UUID        REFERENCES {{BUSINESS}}.product_variants (variant_id) ON DELETE SET NULL,
  qty_used              NUMERIC(10,3) NOT NULL CHECK (qty_used > 0),
  unit                  TEXT        NOT NULL,                  -- 'ml','g','units'
  cost_ngn              NUMERIC(14,2),                          -- allocated cost
  notes                 TEXT,
  recorded_by           UUID        REFERENCES shared.users (user_id) ON DELETE SET NULL,
  recorded_at           TIMESTAMPTZ NOT NULL DEFAULT now()
);
CREATE INDEX idx_{{BUSINESS}}_service_job_chemicals_job
  ON {{BUSINESS}}.service_job_chemicals (job_id);
CREATE INDEX idx_{{BUSINESS}}_service_job_chemicals_chemical
  ON {{BUSINESS}}.service_job_chemicals (chemical_name);

-- ── monthly_chemical_reconciliations ─────────────────────
-- Month-end check: chemical bought (purchasing) vs chemical consumed
-- (service_job_chemicals). Variance flagged as anti-pocketing signal.
CREATE TABLE {{BUSINESS}}.monthly_chemical_reconciliations (
  reconciliation_id     UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  fiscal_period_id      UUID        NOT NULL REFERENCES {{BUSINESS}}.fiscal_periods (period_id),
  chemical_name         TEXT        NOT NULL,
  unit                  TEXT        NOT NULL,
  qty_purchased         NUMERIC(12,3) NOT NULL DEFAULT 0,
  qty_consumed          NUMERIC(12,3) NOT NULL DEFAULT 0,
  qty_disposed          NUMERIC(12,3) NOT NULL DEFAULT 0,
  qty_variance          NUMERIC(12,3) GENERATED ALWAYS AS (qty_purchased - qty_consumed - qty_disposed) STORED,
  variance_value_ngn    NUMERIC(14,2),
  variance_status       TEXT        DEFAULT 'normal'
                        CHECK (variance_status IN ('normal','flagged','investigated','resolved')),
  investigation_notes   TEXT,
  computed_at           TIMESTAMPTZ NOT NULL DEFAULT now(),
  UNIQUE (fiscal_period_id, chemical_name, unit)
);
CREATE INDEX idx_{{BUSINESS}}_chem_recon_flagged
  ON {{BUSINESS}}.monthly_chemical_reconciliations (computed_at DESC)
  WHERE variance_status = 'flagged';

